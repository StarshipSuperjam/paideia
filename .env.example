# Engine-side build tooling environment.
#
# The iOS app does NOT consume this file. Under BYOK (per ADR 0065), users
# provide their Anthropic API key via in-app onboarding into iOS Keychain;
# the app does not read from .env at any point.
#
# Variables below are for engine-side scripts (validate.py graph audit,
# health-check tooling, etc.) — maintainer-only.

# Anthropic API — used by engine-side build tooling (separate from Claude Code's Max subscription)
ANTHROPIC_API_KEY=

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Postgres connection string for engine/tools/validate.py's graph audit
# (Phase 4+, per ADR 0016). Service-role pooler URL — bypasses RLS to
# observe ground truth, distinct from anon access. Format:
# postgresql://postgres.<project-ref>:<service-role-pw>@aws-0-<region>.pooler.supabase.com:5432/postgres
# When unset, validate_graph() records graph_audit_skipped and emits
# no hard-fails or soft-warns; non-seed-authoring sessions are not
# gated on DB connectivity.
SUPABASE_DB_URL=

# Amazon Associates (deferred — populate when commerce layer lands)
AMAZON_ASSOCIATES_TAG=
