# Environment
.env
.env.local
.env.*.local

# Claude Code per-project config
# Top-level .claude/ contents are local-only EXCEPT .claude/commands/ (slash
# commands, e.g., /start-engine), .claude/skills/ (user-defined Skills
# per ADR 0044), and .claude/settings.json (project-scoped hooks per
# ADR 0043).
# settings.local.json remains gitignored — it carries per-developer permissions.
.claude/*
!.claude/commands/
!.claude/commands/*
!.claude/skills/
!.claude/skills/**
!.claude/settings.json

# MCP server config — contains secret access tokens, kept local-only
.mcp.json

# Node
node_modules/
dist/
build/
.next/
.vercel/

# Python (audit_graph.py and tooling will arrive in Phase 4)
__pycache__/
*.py[cod]
.venv/
venv/

# pytest-cov artifacts per ADR 0074 (S-0136). Coverage data + xml report
# are regenerated on every pytest --cov run; do not commit.
.coverage
.coverage.*
coverage.xml
htmlcov/

# pytest --cov log artifact written by the CI step + local sanity runs.
pytest.log

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log
npm-debug.log*

# Per-clone validate.py telemetry (consumed by health checks; per-AI-local).
engine/tools/validate-history.jsonl

# Engine-memory substrate (SQLite + FTS5) per ADR 0091. Single per-clone
# file at the main repo root (resolved via git rev-parse --git-common-dir
# so all worktrees share it); gitignored so substrate data stays local-only.
# Cross-device continuity is user-managed. File regenerates empty on first
# connect at a new clone.
engine/.memory/*
!engine/.memory/.gitkeep

# Per-session engine_memory telemetry (PostToolUse hook appends; scan tool
# rolls up at shutdown step 2 and truncates per ADR 0091). Ephemeral
# per-session work file; never tracked. Unmasked at S-0194 by an
# MCP-call-during-plan-mode pattern that pre-S-0194 sessions hadn't
# exercised.
engine/session/current_engine_memory.jsonl
