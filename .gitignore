# Environment
.env
.env.local
.env.*.local

# Claude Code per-project config
# Top-level .claude/ contents are local-only EXCEPT .claude/commands/, which
# ships project-scoped slash commands (e.g., /start-engine) with the repo.
.claude/*
!.claude/commands/
!.claude/commands/*

# MCP server config — contains secret access tokens, kept local-only
.mcp.json

