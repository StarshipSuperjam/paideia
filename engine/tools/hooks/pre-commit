#!/bin/bash
#
# Paideia pre-commit hook.
#
# Enforces the bimodal session protocol and runs engine/tools/validate.py.
# Paths reflect the post-S-0024 engine/product partition per ADR 0037.
#
# Three modes detected from engine/session/ state + staged changes:
#
#   build     — current.json exists with status: in_progress.
#               All commits permitted (subject to validate.py passing).
#
#   closing   — current.json was deleted in the staged commit (via git mv to
#               engine/session/archive/) AND register_state.json transitions
#               to current_status: "closed". This is the legitimate
#               session-close commit; allowed.
#
#   exploration — neither of the above. Default mode for design-partner work.
#               Restricts commits to: .claude/plans/, HANDOFF.md,
#               product/docs/tensions.md, engine/scheduled_audits.json.
#               Anything else triggers a refusal with a pointer to /start-engine.
#               (product/docs/ideation.md was in this list pre-S-0083; the file
#               retired at S-0083 per Issue #29 — its function migrated to
#               GitHub Issues with the `enhancement` label per ADR 0048.)
#
# Validation always runs, regardless of mode. Hard-fails block the commit;
# soft-warns are advisory.

set -e

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

CURRENT_FILE="engine/session/current.json"
REGISTER_FILE="engine/session/register_state.json"

# ---------------------------------------------------------------------------
# Mode detection
# ---------------------------------------------------------------------------

MODE="exploration"

if [ -f "$CURRENT_FILE" ]; then
    if grep -q '"status": *"in_progress"' "$CURRENT_FILE" 2>/dev/null; then
        MODE="build"
    fi
fi

# Detect close commit: staged changes include deletion or rename of current.json
# AND register_state.json (staged) shows current_status: "closed"
STAGED_CURRENT_OP=$(git diff --cached --name-status -- "$CURRENT_FILE" 2>/dev/null | awk '{print $1}' | head -1)
if [ "$MODE" != "build" ]; then
    if [ "$STAGED_CURRENT_OP" = "D" ] || [ "${STAGED_CURRENT_OP:0:1}" = "R" ]; then
        STAGED_REGISTER=$(git show :"$REGISTER_FILE" 2>/dev/null || echo "")
        if echo "$STAGED_REGISTER" | grep -q '"current_status": *"closed"'; then
            MODE="closing"
        fi
    fi
fi

# ---------------------------------------------------------------------------
# Mode enforcement
# ---------------------------------------------------------------------------

if [ "$MODE" = "exploration" ]; then
    # Allowed in exploration mode:
    #   .claude/plans/                  plan files
    #   HANDOFF.md                      running log
    #   product/docs/tensions.md        open questions
    #   engine/scheduled_audits.json    between-session scheduling surface
    #                                   (added at S-0033 per HANDOFF.md Item 3
    #                                   to fix the self-inflicted barrier where
    #                                   scheduling a near-term audit required
    #                                   opening a session)
    # (product/docs/ideation.md retired at S-0083 per Issue #29; ideas now go
    # to GitHub Issues with the `enhancement` label per ADR 0048.)
    DISALLOWED=$(git diff --cached --name-only \
        | grep -v -E '^\.claude/plans/' \
        | grep -v -E '^HANDOFF\.md$' \
        | grep -v -E '^product/docs/tensions\.md$' \
        | grep -v -E '^engine/scheduled_audits\.json$' \
        || true)
    if [ -n "$DISALLOWED" ]; then
        echo "[pre-commit] Exploration-mode commit blocked." >&2
        echo "" >&2
        echo "  Default-mode posture is design partner — no commits to tracked" >&2
        echo "  project files. Allowed paths in this mode:" >&2
        echo "    .claude/plans/                 (plan files)" >&2
        echo "    HANDOFF.md                     (running log)" >&2
        echo "    product/docs/tensions.md       (open questions)" >&2
        echo "    engine/scheduled_audits.json   (between-session scheduling)" >&2
        echo "" >&2
        echo "  Disallowed staged paths:" >&2
        echo "$DISALLOWED" | sed 's/^/    /' >&2
        echo "" >&2
        echo "  Run /start-engine to convert to a build session, then retry." >&2
        exit 1
    fi
fi

# ---------------------------------------------------------------------------
# Run engine/tools/validate.py (repo-structure + graph stub)
# ---------------------------------------------------------------------------

if [ -f engine/tools/validate.py ]; then
    # `cmd || STATUS=$?` preserves set -e (the || makes the failure "checked")
    # AND captures cmd's actual exit code. The earlier `if ! cmd; then STATUS=$?`
    # form always set STATUS to 0 — the negated pipeline's success — which
    # silently swallowed hard-fails (S-0033 Item 1).
    STATUS=0
    python3 engine/tools/validate.py || STATUS=$?
    if [ "$STATUS" -ge 2 ]; then
        echo "[pre-commit] engine/tools/validate.py reported hard-fails. Commit blocked." >&2
        exit 1
    fi
    # exit 1 from validate.py = soft-warns only; advisory, don't block
fi

# ---------------------------------------------------------------------------
# Routine-mode scope-check + master-plan-integrity (per ADR 0051)
# Hard-fails staged commits that touch task-deliverable paths outside the
# active task's scope_lock (∪ operational allowlist), or that mutate
# auto_target.json keys other than tasks[*].status / tasks[*].blocked_reason
# from a routine-mode session. The check tool itself detects routine-mode
# (auto_target.json + current_plan.md + in_progress task) and exits 0
# silently when not applicable, so always-invoking is safe.
# ---------------------------------------------------------------------------

if [ -f engine/session/auto_target.json ] && [ -f engine/tools/check_routine_scope.py ]; then
    STATUS=0
    python3 engine/tools/check_routine_scope.py --staged || STATUS=$?
    if [ "$STATUS" -eq 1 ]; then
        echo "[pre-commit] routine-mode scope-check failed. Commit blocked." >&2
        echo "  See engine/operations/routine-mode-operations.md for the scope-lock model." >&2
        exit 1
    fi
    if [ "$STATUS" -ge 2 ]; then
        echo "[pre-commit] routine-mode scope-check tool error (exit $STATUS). Commit blocked." >&2
        exit 1
    fi
fi

# ---------------------------------------------------------------------------
# Worktree settings.json sync check (per Issue #5 / S-0048)
# When a Claude Code session runs inside a git worktree, harness Writes to
# .claude/settings.json land in the *main* repo's copy, not the worktree's
# tracked copy. This guard hard-fails any commit from a worktree where
# main's and the worktree's settings.json differ AND the worktree's copy
# is not staged for the current commit (which would mean the user has
# already cp'd the divergence into the worktree's copy).
# Silent no-op when not in a worktree or when files are in sync.
# ---------------------------------------------------------------------------

if [ -f engine/tools/check_settings_sync.py ]; then
    STATUS=0
    python3 engine/tools/check_settings_sync.py || STATUS=$?
    if [ "$STATUS" -eq 1 ]; then
        echo "[pre-commit] worktree settings.json desync detected. Commit blocked." >&2
        exit 1
    fi
    if [ "$STATUS" -ge 2 ]; then
        echo "[pre-commit] settings.json sync check tool error (exit $STATUS). Commit blocked." >&2
        exit 1
    fi
fi

# ---------------------------------------------------------------------------
# Run gitleaks against the staged diff (per ADR 0067).
# Hard-fails any commit that introduces a secret matching gitleaks' default
# rule set OR a project-specific rule, except matches inside the project
# allowlist in engine/tools/gitleaks.toml. Runs before the code-discipline
# gates so the cheapest fail path is checked first.
# ---------------------------------------------------------------------------

if [ -f engine/tools/gitleaks.toml ]; then
    if command -v gitleaks >/dev/null 2>&1; then
        STATUS=0
        gitleaks protect --staged \
            --config engine/tools/gitleaks.toml \
            --redact --no-banner \
            >/dev/null 2>&1 || STATUS=$?
        if [ "$STATUS" -ne 0 ]; then
            echo "[pre-commit] gitleaks detected a secret in the staged diff. Commit blocked." >&2
            # Re-run with output visible so the redacted finding lands on the
            # maintainer's terminal. --redact masks the matched value so the
            # secret itself doesn't end up in scrollback.
            gitleaks protect --staged \
                --config engine/tools/gitleaks.toml \
                --redact --no-banner >&2 || true
            echo "" >&2
            echo "  See engine/adr/0067-gitleaks-pre-commit-secret-scanning.md for the contract." >&2
            echo "  Add an allowlist entry to engine/tools/gitleaks.toml only with a same-commit inline reason." >&2
            exit 1
        fi
    else
        echo "[pre-commit] gitleaks not installed. Commit blocked." >&2
        echo "  Install: brew install gitleaks  (Darwin/macOS)" >&2
        echo "  See engine/operations/dependency-discipline.md 'External tool prerequisites'." >&2
        echo "  Pinned version: 8.30.1 (see engine/adr/0067-gitleaks-pre-commit-secret-scanning.md)." >&2
        exit 1
    fi
fi

# ---------------------------------------------------------------------------
# Run code-discipline gates against staged Python files under engine/
# (Layer 2 of ADR 0038 — ruff, mypy --strict, pytest, test_presence)
# ---------------------------------------------------------------------------

STAGED_PY=$(git diff --cached --name-only --diff-filter=ACMR \
    | grep -E '^engine/.*\.py$' || true)

if [ -n "$STAGED_PY" ] && [ -f engine/tools/validate.py ]; then
    STATUS=0
    # shellcheck disable=SC2086
    python3 engine/tools/validate.py --code-gates --files $STAGED_PY || STATUS=$?
    if [ "$STATUS" -ge 2 ]; then
        echo "[pre-commit] engine/tools/validate.py --code-gates reported hard-fails. Commit blocked." >&2
        echo "  See engine/operations/code-discipline.md for the gate-stack contract." >&2
        exit 1
    fi
fi

# ---------------------------------------------------------------------------
# Run SQL-discipline gates against staged migration files
# (Layer 2 of ADR 0039 + migration-discipline.md — transaction wrap,
#  CASCADE on FKs to users(id), RLS-enable on public.* tables, CHECK
#  constraint shape on enum-modeled TEXT columns)
# ---------------------------------------------------------------------------

STAGED_SQL=$(git diff --cached --name-only --diff-filter=ACMR \
    | grep -E '^product/seed-graph/migrations/.*\.sql$' || true)

if [ -n "$STAGED_SQL" ] && [ -f engine/tools/validate.py ]; then
    STATUS=0
    # shellcheck disable=SC2086
    python3 engine/tools/validate.py --sql-gates --files $STAGED_SQL || STATUS=$?
    if [ "$STATUS" -ge 2 ]; then
        echo "[pre-commit] engine/tools/validate.py --sql-gates reported hard-fails. Commit blocked." >&2
        echo "  See engine/operations/migration-discipline.md for the gate-stack contract." >&2
        exit 1
    fi
fi

# ---------------------------------------------------------------------------
# Run HANDOFF-disposition audit on closing commits
# (per CLAUDE.md "Default to fix-in-context", added at S-0036).
# Every new HANDOFF.md section authored during the session must carry an
# explicit **Disposition:** line; the audit hard-fails the close otherwise.
# ---------------------------------------------------------------------------

if [ "$MODE" = "closing" ] && [ -f engine/tools/audit_handoff_dispositions.py ]; then
    STATUS=0
    python3 engine/tools/audit_handoff_dispositions.py || STATUS=$?
    if [ "$STATUS" -ge 2 ]; then
        echo "[pre-commit] HANDOFF.md disposition audit hard-failed. Close blocked." >&2
        echo "  See CLAUDE.md 'Default to fix-in-context' for the contract." >&2
        exit 1
    fi
fi

# ---------------------------------------------------------------------------
# Run archive-structured-fields audit on closing commits
# (per ADR 0042 + Issue #13, added at S-0055).
# Defends the persistent-warn surface against silent field-absence lapses.
# ---------------------------------------------------------------------------

if [ "$MODE" = "closing" ] && [ -f engine/tools/audit_archive_structured_fields.py ]; then
    # The closing commit deletes current.json and adds the archive file.
    # Find the staged archive path and pipe its content through the audit.
    # --diff-filter=AR catches both `cp + rm + git add` (status A) and
    # `git mv current.json archive/S-NNNN.json` (status R) close shapes
    # per Issue #56. Pre-S-0118 this used --diff-filter=A only, which
    # silently skipped the audit on git-mv closes (tripped at S-0076 and
    # S-0106). With --name-only, --diff-filter=AR outputs the destination
    # path for renames, so the existing grep pattern still matches.
    ARCHIVE_PATH=$(git diff --cached --name-only --diff-filter=AR \
        | grep -E '^engine/session/archive/S-[0-9]{4}\.json$' \
        | head -1)
    if [ -n "$ARCHIVE_PATH" ]; then
        STATUS=0
        git show ":$ARCHIVE_PATH" \
            | python3 engine/tools/audit_archive_structured_fields.py --from-stdin \
            || STATUS=$?
        if [ "$STATUS" -ge 2 ]; then
            echo "[pre-commit] archive structured-fields audit hard-failed. Close blocked." >&2
            echo "  See ADR 0042 + engine/operations/session-shutdown-sequence.md." >&2
            exit 1
        fi
    fi
fi

echo "[pre-commit] Mode: $MODE — OK"
exit 0
